{
  "name": "fe-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-level fashion eCommerce platform",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fe-platform/web",
    "dev:admin": "turbo run dev --filter=@fe-platform/admin",
    "dev:api": "turbo run dev --filter=@fe-platform/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@fe-platform/web",
    "build:admin": "turbo run build --filter=@fe-platform/admin",
    "build:api": "turbo run build --filter=@fe-platform/api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:security": "pnpm --filter @fe-platform/api test:security",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky",
    "setup": "node scripts/setup-env.mjs",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:infra": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "eslint": "9.39.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
