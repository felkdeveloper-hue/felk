{
  "name": "@fe-platform/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utility helpers for FE Platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@fe-platform/eslint-config": "workspace:*",
    "@fe-platform/tsconfig": "workspace:*",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
