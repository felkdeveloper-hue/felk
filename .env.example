# =============================================================================
# FE Platform — Root Environment Template
# Copy to .env and fill in values. Never commit real secrets.
# =============================================================================

# ---------- General ----------
NODE_ENV=development
APP_NAME=fe-platform
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
API_URL=http://localhost:4000
API_PREFIX=/api/v1

# ---------- Server ----------
PORT=4000
HOST=0.0.0.0
TRUST_PROXY=1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
SWAGGER_ENABLED=true
CSRF_ENABLED=false
METRICS_ENABLED=true
PRODUCTION_STRICT=false

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/fe-platform
MONGODB_URI_TEST=mongodb://localhost:27017/fe-platform-test

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ---------- JWT ----------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_NAME=fe_refresh_token

# ---------- Session / Cookies ----------
COOKIE_SECRET=change-me-cookie-secret-min-32-chars!!!!
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---------- Email / SMTP (Zoho) ----------
SMTP_ENABLED=true
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Fashion Edge <system@technixinc.com>"
FROM_EMAIL=system@technixinc.com
FROM_NAME=Fashion Edge

# ---------- Cloudflare R2 (preferred object storage) ----------
# When R2 credentials are set, all uploads (product images, reviews, etc.) go to R2.
STORAGE_PROVIDER=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Public URL for uploaded files (custom domain or r2.dev public bucket URL)
R2_PUBLIC_URL=

# ---------- Cloudflare ----------
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CDN_BASE_URL=

# ---------- AWS S3 (alternative object storage) ----------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fe-platform-assets
AWS_S3_ENDPOINT=
S3_PUBLIC_URL=

# ---------- Uploads ----------
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/avif

# ---------- Logging ----------
LOG_LEVEL=debug
MORGAN_FORMAT=dev

# ---------- Payment Engine (Phase 10) ----------
PAYMENT_RETURN_URL=http://localhost:5173/payment/return
PAYMENT_CANCEL_URL=http://localhost:5173/payment/cancel
PAYMENT_ATTEMPT_TTL_MINUTES=30
PAYMENT_MAX_RETRY_ATTEMPTS=5

PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox

KOKO_MERCHANT_ID=
KOKO_SECRET_KEY=
KOKO_API_KEY=
KOKO_PRIVATE_KEY_PATH=config/koko_private.pem

MINTPAY_MERCHANT_ID=
MINTPAY_MERCHANT_SECRET=
MINTPAY_MODE=sandbox

COD_WEBHOOK_SECRET=

# ---------- Meta Conversions API ----------
META_CAPI_TOKEN=
META_PIXEL_ID=

# ---------- TikTok Events API ----------
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# ---------- Frontend (Vite) ----------
VITE_API_URL=http://localhost:4000/api/v1
VITE_APP_NAME=FE Platform
VITE_CDN_URL=
VITE_SOCKET_URL=http://localhost:4000
