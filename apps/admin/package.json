{
  "name": "@fe-platform/admin",
  "version": "0.1.0",
  "private": true,
  "description": "Admin dashboard for FE Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@fe-platform/config": "workspace:*",
    "@fe-platform/types": "workspace:*",
    "@fe-platform/ui": "workspace:*",
    "@fe-platform/utils": "workspace:*",
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.62.11",
    "@tanstack/react-router": "^1.93.6",
    "axios": "^1.7.9",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@fe-platform/eslint-config": "workspace:*",
    "@fe-platform/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "msw": "^2.15.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "@types/node": "^22.10.2",
    "vitest": "^4.1.10"
  }
}
