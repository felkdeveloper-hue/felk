NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_NAME=fe-platform
APP_VERSION=0.1.0
API_PREFIX=/api/v1
API_DOCS_PATH=/api/docs
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
MONGODB_URI=mongodb://localhost:27017/fe-platform
MONGODB_MAX_POOL_SIZE=10
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=fe:
JWT_ACCESS_SECRET=dev-access-secret-change-me!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=dev-cookie-secret-change-me!!!
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=debug
MORGAN_FORMAT=dev
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/avif
SHUTDOWN_TIMEOUT_MS=15000
EMAIL_FROM="Fashion Edge <system@technixinc.com>"
SMTP_ENABLED=true
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=system@technixinc.com
FROM_NAME=Fashion Edge

# ---------- Optional local account seed ----------
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=
LOCAL_CUSTOMER_EMAIL=
LOCAL_CUSTOMER_PASSWORD=

# ---------- Payment Engine (Phase 10) ----------
PAYMENT_RETURN_URL=http://localhost:5173/payment/return
PAYMENT_CANCEL_URL=http://localhost:5173/payment/cancel
PAYMENT_ATTEMPT_TTL_MINUTES=30
PAYMENT_MAX_RETRY_ATTEMPTS=5

PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox

KOKO_MERCHANT_ID=
KOKO_SECRET_KEY=
KOKO_API_KEY=
KOKO_PRIVATE_KEY_PATH=config/koko_private.pem
KOKO_MODE=sandbox

MINTPAY_MERCHANT_ID=
MINTPAY_MERCHANT_SECRET=
MINTPAY_MODE=sandbox

COD_WEBHOOK_SECRET=

# ---------- Meta Conversions API ----------
META_CAPI_TOKEN=
META_PIXEL_ID=

# ---------- TikTok Events API ----------
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
