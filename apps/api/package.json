{
  "name": "@fe-platform/api",
  "version": "0.1.0",
  "private": true,
  "description": "FE Platform REST API — Express + MongoDB",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:auth": "tsx src/scripts/seed-auth.ts",
    "seed:catalog": "tsx src/scripts/seed-mock-catalog.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:edge": "vitest run src/test/edge-cases.test.ts",
    "test:flows": "vitest run src/test/flows.test.ts",
    "test:security": "vitest run src/test/security.test.ts",
    "test:performance": "vitest run src/test/performance.test.ts",
    "test:load": "node src/test/load/load-test.mjs",
    "clean": "rimraf dist .turbo logs"
  },
  "dependencies": {
    "@fe-platform/config": "workspace:*",
    "@fe-platform/types": "workspace:*",
    "@fe-platform/utils": "workspace:*",
    "argon2": "^0.44.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@fe-platform/eslint-config": "workspace:*",
    "@fe-platform/tsconfig": "workspace:*",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.1",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.17.0",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
